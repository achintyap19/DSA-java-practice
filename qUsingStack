import java.util.Queue;
import java.util.LinkedList;


class qUsingStack{
    Queue <Integer> q = new LinkedList<>();

    void push(int x){
        q.poll(x);
        for(int i=0;i<q.size()-1;i++){
            q.offer(q.poll());
        }
    }

    public int pop(){
        return q.poll();
    }
}